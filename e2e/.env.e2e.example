# Required — Lemon Squeezy test mode credentials
E2E_LS_API_KEY=                          # Test mode API key
E2E_LS_STORE_ID=                         # Test store ID
E2E_LS_WEBHOOK_SECRET=                   # Webhook signing secret

# Required — Test products
E2E_LS_PRO_PRODUCT_ID=                   # Pro plan product ID
E2E_LS_PRO_MONTHLY_VARIANT_ID=           # Pro monthly variant
E2E_LS_PRO_ANNUAL_VARIANT_ID=            # Pro annual variant
E2E_LS_ENTERPRISE_PRODUCT_ID=            # Enterprise plan product ID
E2E_LS_ENTERPRISE_MONTHLY_VARIANT_ID=    # Enterprise monthly variant
E2E_LS_ENTERPRISE_ANNUAL_VARIANT_ID=     # Enterprise annual variant

# Optional — Tunnel configuration
E2E_TUNNEL_URL=                          # Pre-configured tunnel URL (skip auto-tunnel if set)

# Optional — Playwright
E2E_HEADLESS=true                        # Run browser headless (default: true)
E2E_SLOW_MO=0                            # Slow down browser actions in ms (useful for debugging)
