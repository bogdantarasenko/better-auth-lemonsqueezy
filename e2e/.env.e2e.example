# Required — Lemon Squeezy test mode credentials
LEMONSQUEEZY_API_KEY=                          # Test mode API key
LEMONSQUEEZY_STORE_ID=                         # Test store ID
LEMONSQUEEZY_WEBHOOK_SIGNING_SECRET=                   # Webhook signing secret

# Required — Test products
LEMONSQUEEZY_PRO_PRODUCT_ID=                   # Pro plan product ID
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=           # Pro monthly variant
LEMONSQUEEZY_PRO_ANNUAL_VARIANT_ID=            # Pro annual variant
LEMONSQUEEZY_MAX_PRODUCT_ID=                   # Max plan product ID
LEMONSQUEEZY_MAX_MONTHLY_VARIANT_ID=           # Max monthly variant
LEMONSQUEEZY_MAX_ANNUAL_VARIANT_ID=            # Max annual variant

# Optional — Tunnel configuration
E2E_TUNNEL_URL=                          # Pre-configured tunnel URL (skip auto-tunnel if set)

# Optional — Playwright
E2E_HEADLESS=true                        # Run browser headless (default: true)
E2E_SLOW_MO=0                            # Slow down browser actions in ms (useful for debugging)
