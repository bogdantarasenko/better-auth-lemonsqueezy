{
  "name": "better-auth-lemonsqueezy",
  "version": "0.1.0",
  "description": "Lemon Squeezy plugin for Better Auth — subscription management, webhooks, and access control",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./mcp": {
      "import": "./src/mcp/index.ts",
      "types": "./src/mcp/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./client": {
        "import": "./dist/client.js",
        "types": "./dist/client.d.ts"
      },
      "./mcp": {
        "import": "./dist/mcp/index.js",
        "types": "./dist/mcp/index.d.ts"
      }
    }
  },
  "bin": {
    "better-auth-lemonsqueezy-mcp": "./dist/mcp/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "mcp-server": "npx tsx scripts/mcp-dev.ts"
  },
  "peerDependencies": {
    "better-auth": ">=1.2.0",
    "zod": ">=3.20.0",
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-auth": "^1.2.9",
    "better-sqlite3": "^12.8.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "better-auth",
    "lemonsqueezy",
    "lemon-squeezy",
    "subscription",
    "payments"
  ]
}
